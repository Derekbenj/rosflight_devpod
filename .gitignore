# ROS 2 build artifacts
/build/
/install/
/log/

# ROSflight source repositories — cloned by scripts/setup_workspace.sh.
# They are kept out of this repo so it stays a lightweight, reproducible
# DevPod template. Run the setup script (or `devpod up`) to populate them.
/src/rosflight_ros_pkgs/
/src/rosplane/
/src/roscopter/

# Veloxity is cloned into ~/Veloxity inside the container. Keep this guard for
# users who override VELOXITY_ROOT to a checkout under the workspace.
/Veloxity/

# Claude Code local (user-specific) settings
.claude/settings.local.json

# Editor / OS cruft
*.swp
*.swo
*~
.DS_Store
.idea/
